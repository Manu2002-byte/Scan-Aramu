import streamlit as st
import cv2
import numpy as np
import json
import os

# Configurazione pagina stile Mobile
st.set_page_config(page_title="Corriere Scanner App", page_icon="🚚", layout="centered")

FILE_MEMORIA = "memoria_merci.json"

def carica_memoria_storica():
    if os.path.exists(FILE_MEMORIA):
        with open(FILE_MEMORIA, "r") as f:
            try:
                return json.load(f)
            except:
                return {}
    return {}

def salva_in_memoria_storica(codice, tipologia):
    memoria = carica_memoria_storica()
    memoria[codice] = tipologia.strip()
    with open(FILE_MEMORIA, "w") as f:
        json.dump(memoria, f)

if "database_merci" not in st.session_state:
    st.session_state.database_merci = {}
if "codice_corrente" not in st.session_state:
    st.session_state.codice_corrente = None

st.title("🚚 Assistente di Carico STABILE")

modalita = st.radio("Cosa stai facendo adesso?", ["Fase 1: Carico Furgone (Associa)", "Fase 2: Consegna (Verifica Scarico)"])

def rileva_codice(file_immagine):
    if file_immagine is not None:
        try:
            bytes_data = file_immagine.read()
            cv2_img = cv2.imdecode(np.frombuffer(bytes_data, np.uint8), cv2.IMREAD_COLOR)
            detector = cv2.BarcodeDetector()
            retval, decoded_info, decoded_type = detector.detectAndDecode(cv2_img)
            if retval and len(decoded_info) > 0:
                return decoded_info[0].strip()
        except Exception as e:
            pass
    return None

# --- FASE 1: CARICO FURGONE ---
if modalita == "Fase 1: Carico Furgone (Associa)":
    st.header("📦 Associa Merce e Destinazione")
    
    destinazione = st.text_input("Scrivi la Destinazione (es: Cliente Rossi...)", "").strip()
    
    if destinazione:
        st.write("Scatta una foto al codice a barre:")
        # Questo comando apre direttamente la fotocamera nativa dello smartphone senza bug
        foto_pacco = st.file_uploader("Premi qui per FARE LA FOTO", type=["jpg", "jpeg", "png"], key="carico_file")
        
        if foto_pacco:
            codice = rileva_codice(foto_pacco)
            if codice:
                st.session_state.codice_corrente = codice
                memoria_storica = carica_memoria_storica()
                
                if codice in memoria_storica:
                    tipologia_conosciuta = memoria_storica[codice]
                    st.session_state.database_merci[codice] = {
                        "destinazione": destinazione, 
                        "tipologia": tipologia_conosciuta,
                        "scaricato": False
                    }
                    st.success(f"🧠 Riconosciuto! **{tipologia_conosciuta}** associato a **{destinazione}**.")
                    st.session_state.codice_corrente = None
                else:
                    st.warning(f"🔍 Nuovo codice rilevato: **{codice}**")
            else:
                st.error("❌ Codice non rilevato nella foto. Assicurati che sia a fuoco e riprova.")
        
        if st.session_state.codice_corrente:
            nuova_tipologia = st.text_input("Scrivi cos'è (es. Bancale, Sacco, Fusto...):", key="input_tipo").strip()
            
            if st.button("Salva e Associa al furgone"):
                if nueva_tipologia:
                    cod = st.session_state.codice_corrente
                    salva_in_memoria_storica(cod, nuova_tipologia)
                    st.session_state.database_merci[cod] = {
                        "destinazione": destinazione, 
                        "tipologia": nuova_tipologia, 
                        "scaricato": False
                    }
                    st.success(f"💾 Salvato!")
                    st.session_state.codice_corrente = None
                else:
                    st.error("Inserisci un nome per la merce.")

    if st.session_state.database_merci:
        st.subheader("📋 Nel furgone adesso:")
        for cod, info in st.session_state.database_merci.items():
            st.text(f"🔹 {info['tipologia']} ➡️ {info['destinazione']} (Cod: {cod})")

# --- FASE 2: CONSEGNA (SCARICO) ---
else:
    st.header("🏁 Verifica Scarico Merce")
    
    destinazioni_disponibili = list(set([info["destinazione"] for info in st.session_state.database_merci.values()]))
    
    if not destinazioni_disponibili:
        st.info("Il furgone è vuoto!")
    else:
        destinazione_corrente = st.selectbox("Seleziona dove sei arrivato:", destinazioni_disponibili)
        merci_da_consegnare = {k: v for k, v in st.session_state.database_merci.items() if v["destinazione"] == destinazione_corrente}
        
        st.subheader("Lista colli da scaricare qui:")
        tutti_scaricati = True
        for cod, info in merci_da_consegnare.items():
            stato = "🟢 SCARICATO" if info["scaricato"] else "🔴 DA SCARICARE"
            if not info["scaricato"]:
                tutti_scaricati = False
            st.write(f"• **{info['tipologia']}** (Cod: {cod}) — Stato: {stato}")
            
        if tutti_scaricati:
            st.success("🎉 Tutto scaricato qui!")
        else:
            st.warning("⚠️ Mancano colli. Fai una foto al codice per scaricare:")
            foto_scarico = st.file_uploader("Premi qui per FARE LA FOTO", type=["jpg", "jpeg", "png"], key="scarico_file")
            
            if foto_scarico:
                codice_scansionato = rileva_codice(foto_scarico)
                if codice_scansionato:
                    if codice_scansionato in merci_da_consegnare:
                        st.session_state.database_merci[codice_scansionato]["scaricato"] = True
                        st.success(f"🎯 Verificato!")
                    elif codice_scansionato in st.session_state.database_merci:
                        dest_corretta = st.session_state.database_merci[codice_scansionato]["destinazione"]
                        st.error(f"🚨 ERRORE! Questo va a: **{dest_corretta}**!")
                    else:
                        st.error("❓ Codice sconosciuto.")
